<simulation verbosity='high'>

  <total_steps>500</total_steps>

  <ffsocket mode='unix' name='driver' pbc='False'>
    <address>lorem</address>
  </ffsocket>

  <output prefix='i-pi'>
    <trajectory filename='forces' format='ase'>forces</trajectory>
    <trajectory filename='Eforces' format='ase'>Eforces</trajectory>
    <trajectory filename='momenta' format='ase'>momenta</trajectory>
    <trajectory filename='velocities' format='ase'>velocities</trajectory>
    <trajectory filename='positions' format='ase'>positions</trajectory>
    <trajectory filename='becx' format='ase'>becx</trajectory>
    <trajectory filename='becy' format='ase'>becy</trajectory>
    <trajectory filename='becz' format='ase'>becz</trajectory>
    <properties filename='properties.out' verbosity='low' > [ step, time, conserved, kinetic_md, potential, Efield, Eenvelope ] </properties>
  </output>

  <prng>
    <seed>10545</seed>
  </prng>

  <system>
    <forces>
      <force forcefield='driver' />
    </forces>

    <initialize nbeads='1'>
      <file mode='ase' units='angstrom' > start.xyz </file>
      <velocities mode='thermal' units='kelvin'> 300 </velocities> 
    </initialize>

    <ensemble>
      <temperature units='kelvin'> 300 </temperature>
    </ensemble>

    <motion mode='driven_dynamics'>
      <driven_dynamics mode='eda-nvt'>
        <timestep units='femtosecond'> 0.5 </timestep>
        <thermostat mode='svr'>
            <tau units='femtosecond'> 100 </tau>
        </thermostat>
        <efield>
          <amp units="v/ang"> [ 0, 0, 0.1 ] </amp>
          <freq units="thz"> 0 </freq>
        </efield>
        <bec mode="driver"/>
      <asr_threshold > 1e-5 </asr_threshold>
      </driven_dynamics>
    </motion>

  </system>
</simulation>
